CLOSED_CLAW_DB_PATH=.closed_claw/registry.db
CLOSED_CLAW_AGENTS_DIR=agents
CLOSED_CLAW_RUN_LOGS_DIR=.closed_claw/runs
CLOSED_CLAW_EMBEDDING_MODEL=all-MiniLM-L6-v2
CLOSED_CLAW_ENABLE_SENTENCE_TRANSFORMERS=false
CLOSED_CLAW_EMBEDDING_DIM=384
CLOSED_CLAW_LOW_CONFIDENCE_THRESHOLD=0.62
CLOSED_CLAW_CREATE_APPROVAL_REQUIRED=true
CLOSED_CLAW_CREATE_APPROVAL_MODE=interactive
CLOSED_CLAW_API_APPROVAL_MODE=interactive
CLOSED_CLAW_PAID_API_PROVIDERS=
CLOSED_CLAW_API_APPROVAL_TIMEOUT_SEC=30
CLOSED_CLAW_AGENT_TIMEOUT_SEC=120
CLOSED_CLAW_AGENT_RETRIES=2
CLOSED_CLAW_CIRCUIT_BREAKER_FAILURES=3
CLOSED_CLAW_CIRCUIT_BREAKER_RESET_SEC=120
CLOSED_CLAW_TASK_POOL_POLL_INTERVAL_SEC=30
CLOSED_CLAW_SUBTASK_MAX_ATTEMPTS=2
CLOSED_CLAW_REQUIRE_SQLITE_VEC=true

# ── LLM Provider ──────────────────────────────────────────────────────────────
# Active provider. Choose one: openai | gemini | claude | siemens
CLOSED_CLAW_LLM_PROVIDER=siemens

# ── Siemens (default) ─────────────────────────────────────────────────────────
CLOSED_CLAW_LLM_MODEL=qwen3-30b-a3b-instruct-2507
SIEMENS_API_KEY=
SIEMENS_BASE_URL=https://api.siemens.com/llm

# ── OpenAI ────────────────────────────────────────────────────────────────────
# CLOSED_CLAW_LLM_PROVIDER=openai
# CLOSED_CLAW_LLM_MODEL=gpt-4o-mini
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com

# ── Google Gemini ─────────────────────────────────────────────────────────────
# CLOSED_CLAW_LLM_PROVIDER=gemini
# CLOSED_CLAW_LLM_MODEL=gemini-2.5-flash
# GEMINI_API_KEY=
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com

# ── Anthropic Claude ──────────────────────────────────────────────────────────
# CLOSED_CLAW_LLM_PROVIDER=claude
# CLOSED_CLAW_LLM_MODEL=claude-3-5-haiku-latest
# ANTHROPIC_API_KEY=
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# ── Shared key override (used if provider-specific key above is empty) ─────────
CLOSED_CLAW_LLM_API_KEY=
CLOSED_CLAW_LLM_TIMEOUT_SEC=45

CLOSED_CLAW_EXTRA_ALLOWED_PATHS=
